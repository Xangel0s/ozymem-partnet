# Git
.git
.gitignore

# Build artifacts
target/
*.exe
*.pdb

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Documentation (not needed in container)
docs/
*.md
!README.md

# Docker files (avoid recursive builds)
Dockerfile
docker-compose*.yml
.dockerignore

# Environment files (should be passed via environment variables)
.env
.env.*
!.env.example

# Scripts (not needed in container)
*.ps1
