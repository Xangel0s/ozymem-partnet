# =============================================================================
# OZYMEM-PARTNER Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
# NEVER commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Memgraph Database Credentials
# -----------------------------------------------------------------------------
# These are REQUIRED for security. The application will NOT start without them.
MEMGRAPH_USER=your_secure_username
MEMGRAPH_PASSWORD=your_secure_password

# -----------------------------------------------------------------------------
# OPTIONAL: Memgraph Configuration
# -----------------------------------------------------------------------------
# Default: 127.0.0.1:7687 (local) or memgraph:7687 (Docker)
# MEMGRAPH_URI=127.0.0.1:7687

# Default: memgraph
# MEMGRAPH_DATABASE=memgraph

# -----------------------------------------------------------------------------
# OPTIONAL: Server Configuration
# -----------------------------------------------------------------------------
# Default: 8080
# PORT=8080

# Server mode: "web" for HTTP API, "stdio" for MCP stdio mode
# Default: web (when --web flag is used or OZYMEM_SERVER_MODE=web)
# OZYMEM_SERVER_MODE=web

# -----------------------------------------------------------------------------
# OPTIONAL: Remote Mode (CLI connecting to remote server)
# -----------------------------------------------------------------------------
# URL of the remote ozymem-server HTTP API
# OZYMEM_SERVER_URL=http://your-server:8080

# UUID of the remote server (tenant ID)
# OZYMEM_SERVER_ID=your-server-uuid

# User token for authentication with remote server
# OZYMEM_USER_TOKEN=your_user_token

# -----------------------------------------------------------------------------
# OPTIONAL: MCP Configuration
# -----------------------------------------------------------------------------
# Token for MCP server authentication
# OZYBASE_MCP_TOKEN=your_mcp_token

# Run MCP server in daemon mode (background)
# OZYMEM_DAEMON=true

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# -----------------------------------------------------------------------------
# These are used for local development only. Never use in production!

# Default Memgraph credentials (for local development only)
# MEMGRAPH_USER=admin
# MEMGRAPH_PASSWORD=admin
